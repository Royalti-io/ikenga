{
  "name": "ikenga-desktop",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Ikenga — Tauri 2 desktop app (control plane for terminals, chat, viewer)",
  "scripts": {
    "dev": "bun run iyke:bundle && vite",
    "build": "bun run iyke:bundle && tsc --noEmit && vite build",
    "iyke:bundle": "bun build src/lib/iyke/iframe-bridge.entry.ts --outfile src-tauri/resources/iyke-iframe-bridge.js --target browser --format esm --minify",
    "typecheck": "tsc --noEmit",
    "tsr:generate": "tsr generate",
    "tsr:watch": "tsr watch",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "biome format --write .",
    "lint": "biome lint .",
    "sidecars:build": "bash sidecars/mbox/build.sh && bash sidecars/video-studio/build.sh && bash sidecars/hyperframes/build.sh && bash sidecars/storyboard/build.sh",
    "sidecars:build:copy": "bash scripts/sync-hyperframes-projects.sh --copy && bun run sidecars:build",
    "sync:hyperframes": "bash scripts/sync-hyperframes-projects.sh",
    "design:bundle": "bun run design/scripts/bundle.ts"
  },
  "dependencies": {
