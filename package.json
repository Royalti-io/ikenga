{
	"name": "ikenga-desktop",
	"private": true,
	"version": "0.2.5",
	"license": "Apache-2.0",
	"type": "module",
	"description": "Ikenga — Tauri 2 desktop app (control plane for terminals, chat, viewer)",
	"scripts": {
		"changeset:version": "bunx @changesets/cli version && node scripts/sync-version.mjs",
		"dev": "bun run bun:fetch && bun run iyke:bundle && bun run artifact:bundle && bun run tokens:copy && bun run iyke:mcp:build && vite",
		"build": "bun run iyke:bundle && bun run artifact:bundle && bun run tokens:copy && bun run iyke:mcp:build && vite build",
		"bun:fetch": "bash scripts/fetch-bun.sh",
		"iyke:bundle": "bun build src/lib/iyke/iframe-bridge.entry.ts --outfile src-tauri/resources/iyke-iframe-bridge.js --target browser --format esm --minify",
		"artifact:bundle": "bun build src/lib/artifact/bridge.entry.ts --outfile src-tauri/resources/artifact-iframe-bridge.js --target browser --format esm --minify",
		"tokens:copy": "node -e \"const fs=require('fs');fs.copyFileSync(require.resolve('@ikenga/tokens/tokens.css'),'src-tauri/resources/ikenga-tokens.css')\"",
		"iyke:mcp:build": "bash scripts/build-iyke-mcp.sh",
		"typecheck": "tsc --noEmit",
		"tsr:generate": "tsr generate",
		"tsr:watch": "tsr watch",
		"preview": "vite preview",
		"tauri": "tauri",
		"test": "vitest run",
		"test:watch": "vitest",
		"fmt": "biome format --write .",
		"lint": "biome lint .",
		"engine:smoke": "bun run scripts/engine-wire-smoke.ts"
	},
	"dependencies": {
		"@ikenga/contract": "workspace:*",
		"@ikenga/pkg-engine-claude-code": "^0.2.0",
		"@ikenga/registry-client": "^0.1.0",
		"@ikenga/tokens": "workspace:*",
		"@ikenga/ui-lib": "^0.2.0",
		"@lobehub/icons": "^5.8.0",
		"@modelcontextprotocol/ext-apps": "^1.7.1",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-use-controllable-state": "^1.2.2",
