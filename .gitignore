# dependencies
node_modules/

# bun
bun.lockb

# build
dist/
dist-ssr/
design/_dist/
*.local
*.tsbuildinfo
vite.config.js
vite.config.d.ts

# editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store

# rust
src-tauri/target/

# tauri codegen — regenerated per-platform on cargo build
src-tauri/gen/

# Bundled iyke-mcp binary — regenerated by scripts/build-iyke-mcp.sh
# (runs as part of `bun run build`). Source files in this dir
# (manifest.json, package.json, src/) are tracked; the compiled binary
# is ~100 MB and gets rebuilt per-platform anyway.
src-tauri/resources/builtin-pkgs/com.ikenga.mcp-iyke/bin/
src-tauri/resources/builtin-pkgs/com.ikenga.mcp-iyke/node_modules/

# Bundled Bun runtime (per ADR-010) — fetched per build target by
# scripts/fetch-bun.sh. Pin lives in the script; the binary itself is
# ~50–95 MB and fully reproducible from the pinned SHA, so we don't
# track it.
src-tauri/resources/bun/

# env
.env
.env.local
.env.*.local

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
