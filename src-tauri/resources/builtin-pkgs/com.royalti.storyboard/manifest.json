{
  "id": "com.royalti.storyboard",
  "name": "Storyboard",
  "version": "0.2.0",
  "ikenga_api": "1",
  "kind": "embedded",
  "author": { "name": "Royalti", "key": "royalti" },

  "mcp": [
    {
      "name": "storyboard",
      "command": "./sidecars/pa-storyboard",
      "args": [],
      "lifecycle": "long-lived"
    }
  ],

  "ui": {
    "routes": [
      { "path": "/board", "kind": "iframe", "source": "dist/index.html" }
    ],
    "csp": {
      "connect-src": ["'self'", "http://127.0.0.1:3105", "http://127.0.0.1:3106"]
    }
  },
  "permissions": {
    "fs.read": ["$pkg_install/**", "$home/royalti-co/royalti-video-engine/**"],
    "fs.write": ["$pkg_data/**"]
  },
  "queries": {
    "key_prefixes": ["storyboard"]
  }
}
