# Sidecar binaries are built artifacts (~100MB each) — generated by
# `bun run sidecars:build` and consumed by `tauri build` via the
# resources/builtin-pkgs/**/* bundle glob. Do not commit.
com.royalti.hyperframes/sidecars/pa-hyperframes
com.royalti.video-studio/sidecars/pa-video-studio
com.royalti.storyboard/sidecars/pa-storyboard

# HyperFrames wrapper UI is built from sidecars/hyperframes/wrapper/ — also a
# build artifact, regenerated on every `bun run sidecars:build`.
com.royalti.hyperframes/dist/
