{
  "id": "com.royalti.hyperframes",
  "name": "HyperFrames",
  "version": "0.2.0",
  "ikenga_api": "1",
  "kind": "embedded",
  "author": { "name": "Royalti", "key": "royalti" },

  "mcp": [
    {
      "name": "hyperframes",
      "command": "./sidecars/pa-hyperframes",
      "args": [],
      "lifecycle": "long-lived"
    }
  ],

  "ui": {
    "routes": [
      { "path": "/preview", "kind": "iframe", "source": "dist/index.html" }
    ],
    "csp": {
      "connect-src": ["'self'", "http://127.0.0.1:*"]
    },
    "permissions": {
      "clipboard-read": ["'self'"]
    }
  },
  "permissions": {
    "fs.read": ["$pkg_install/**", "$home/royalti-co/ikenga/shell/hyperframes-projects/**"],
    "fs.write": ["$pkg_data/**"]
  },
  "queries": {
    "key_prefixes": ["hyperframes"]
  },
  "settings": {
    "schema": [
      {
        "key": "default_project",
        "type": "string",
        "label": "Default project",
        "default": "",
        "description": "Project slug to open by default."
      }
    ]
  }
}
