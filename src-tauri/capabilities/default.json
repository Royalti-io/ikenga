{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Phase 1 capability set: pty (custom commands), fs (read/list within ~/royalti-co, ~/.claude/projects, ~/.company), sql, stronghold, dialog, os. Sidecar binaries spawn through tokio::process directly (see src-tauri/src/sidecar/), not through tauri-plugin-shell.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "dialog:default",
    "os:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "stronghold:default",
    "global-shortcut:default",
    "clipboard-manager:allow-write-text",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$HOME/royalti-co/**" },
        { "path": "$HOME/.claude/projects/**" },
        { "path": "$HOME/.company/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$HOME/royalti-co/**" },
        { "path": "$HOME/.claude/projects/**" },
        { "path": "$HOME/.company/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/royalti-co/**" },
        { "path": "$HOME/.claude/projects/**" },
        { "path": "$HOME/.company/**" }
      ]
    }
  ]
}
