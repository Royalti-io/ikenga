{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ikenga",
  "version": "0.2.0",
  "identifier": "app.ikenga",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Royalti-io/ikenga/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI0OUZBQjIyQkVDODNDODIKUldTQ1BNaStJcXVmSkZWeVFvWjVpRy9ick5uNW5EMnRUREpkQUg1K1B6TTJZWlFhUkVtRzVXaEsK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "dmg",
      "app",
      "deb",
      "appimage",
      "nsis"
    ],
    "resources": {
      "resources/builtin-pkgs/**/*": "builtin-pkgs/",
      "resources/bun/**/*": "bun/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
