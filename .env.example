# Ikenga Desktop — environment variables
#
# Copy to `.env.local` and fill in. Vite reads variables prefixed with VITE_
# at build/dev time and inlines them into the renderer bundle.

# Supabase project (the same project as ikenga)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ------------------------------------------------------------------------
# Dev-only stub auth (retained from phase 1, NOT used in normal runs)
# ------------------------------------------------------------------------
# In normal use, the app uses real PKCE auth via /login and the static JWT
# below is ignored. To bypass real auth (e.g. for snapshot tests, CI, or
# headless smoke runs), set BOTH:
#
#     VITE_DEV_FORCE_STUB_AUTH=true
#     VITE_SUPABASE_USER_JWT=<a pre-issued user JWT>
#
# When VITE_DEV_FORCE_STUB_AUTH is unset/false, the JWT is ignored even if
# present. Production builds should leave both blank.
VITE_DEV_FORCE_STUB_AUTH=
VITE_SUPABASE_USER_JWT=
